# ============================================================
# .dockerignore — 排除不需要打入镜像的文件
# ============================================================

# Maven 构建产物 — 仅保留可执行 JAR
target/*.original
target/maven-archiver/
target/maven-status/
target/generated-sources/
target/generated-test-sources/
target/test-classes/

# 源代码（运行时不需要）
src/

# Maven Wrapper
.mvn/
mvnw
mvnw.cmd

# IDE & 临时文件
.apt_generated
.classpath
.factorypath
.project
.settings/
.idea/
*.iml
*.log

# Git
.git/
.gitignore

# 文档 & 图示（非必需）
*.pu
*.md
image/

# 演示模块
demo/

# OS 临时文件
.DS_Store
Thumbs.db
